rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuth(); 
    }

    function isPaciente(rut) {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rut == rut;
    }

    match /citas/{citaId} {
      allow read: if true;
      allow create: if true; 
      allow update: if isAuth() || true; // Permitir temporalmente para pruebas
      allow delete: if isStaff();
    }

    match /resultados/{resultadoId} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if false;
    }

    match /profesionales/{uid} {
      allow read: if true;
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if true;
      allow delete: if isStaff();
    }

    match /horarios/{profId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /bloqueos/{bloqueoId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /users/{uid} {
      allow read: if true; // Permitir lectura para el perfil mock y auth real
      allow create: if true;
      allow update: if true;
    }

    match /users/{uid}/legal/{doc} {
      allow read, write: if true;
    }

    match /tiposAtencion/{tipoId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /asignaciones/{asigId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /imagenes/{imagenId} {
      allow read: if true;
      allow create, update: if isStaff();
      allow delete: if false;
    }
  }
}

