rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuth();
    }

    // ── Citas ────────────────────────────────────────────────────
    match /citas/{citaId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isStaff();
    }

    // ── Resultados (informes eco) ────────────────────────────────
    match /resultados/{resultadoId} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if false;
    }

    // ── Profesionales ────────────────────────────────────────────
    match /profesionales/{uid} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // ── Horarios y bloqueos ──────────────────────────────────────
    match /horarios/{profId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /bloqueos/{bloqueoId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ── Usuarios / Pacientes ─────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isStaff();
    }

    match /users/{uid}/legal/{document} {
      allow read, write: if true;
    }

    // ── Tipos de atención (legado) ───────────────────────────────
    match /tiposAtencion/{tipoId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ── Asignaciones de turno ────────────────────────────────────
    match /asignaciones/{asigId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ── Imágenes ─────────────────────────────────────────────────
    match /imagenes/{imagenId} {
      allow read: if true;
      allow create, update: if isStaff();
      allow delete: if false;
    }

    // ── Colecciones de gestión interna ───────────────────────────
    match /gestion_especialidades/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /gestion_previsiones/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /gestion_prestaciones/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /gestion_metodos_pago/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /gestion_sexos/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ── Usuarios staff (dashboard) ───────────────────────────────
    match /usuarios/{uid} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // ── Pacientes (colección propia del dashboard) ───────────────
    match /pacientes/{pacId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Tipos de atención (legado) ─────────────────────────────
    match /tiposAtencion/{tipoId} {
      allow read: if true;
      allow write: if isStaff();
    }
  }
}
