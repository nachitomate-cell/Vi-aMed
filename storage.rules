rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /imagenes/{imagenId}/{archivo} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }
    match /profesionales_fotos/{archivo} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gestion_protocolos/{archivo} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
